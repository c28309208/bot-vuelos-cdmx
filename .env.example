# Token del bot de Telegram (obtenlo de @BotFather)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ

# ID del canal de Telegram (ejemplo: @mi_canal o -100123456789)
TELEGRAM_CHANNEL_ID=@mi_canal_de_vuelos

# Token de API de Travelpayouts
# Regístrate en https://www.travelpayouts.com y obtén tu token en:
# Herramientas > API > Token de API
TRAVELPAYOUTS_TOKEN=tu_token_de_travelpayouts_aqui

# Marker de afiliado de Travelpayouts (número en tu cuenta)
TRAVELPAYOUTS_MARKER=123456

# Precio máximo en USD para considerar una oferta (opcional, default: 250)
MAX_PRICE_USD=250

# Cada cuántas horas revisar ofertas (opcional, default: 4)
CHECK_INTERVAL_HOURS=4
